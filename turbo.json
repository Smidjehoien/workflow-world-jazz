{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "swc-plugin-workflow#build": {
      "outputs": [
        "target/wasm32-unknown-unknown/release/**",
        "swc_plugin_workflow.wasm"
      ]
    }
  }
}
