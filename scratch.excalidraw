    {
      "id": "29jwYbL5LGvFxGehTPgBe",
      "type": "text",
      "x": 1360.5729044688485,
      "y": -4.595887537230967,
      "width": 374,
      "height": 450,
      "angle": 0.0004998464387586665,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 1889261399,
      "version": 1005,
      "versionNonce": 650351577,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1751136894947,
      "link": null,
      "locked": false,
      "text": "\n\n  fn step(input) {\n    'use step'\n  }\n  step.cacheKey = ({id}) => id;\n\nOR\n  \n  fn step(input) {\n    'use step';\n\n    await useIdempotency(input.id)\n    // throws IdempotencyError\n    // caught by framework\n    // and memoized value is used\n    // upstream\n  }",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\n  fn step(input) {\n    'use step'\n  }\n  step.cacheKey = ({id}) => id;\n\nOR\n  \n  fn step(input) {\n    'use step';\n\n    await useIdempotency(input.id)\n    // throws IdempotencyError\n    // caught by framework\n    // and memoized value is used\n    // upstream\n  }",
      "autoResize": true,
      "lineHeight": 1.25
    },
