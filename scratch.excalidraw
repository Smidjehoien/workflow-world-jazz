    {
      "id": "rIzMdWBNMPAATBY-LIokX",
      "type": "text",
      "x": 2522.8341510993723,
      "y": -171.67768703649887,
      "width": 490.7396240234375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ag",
      "roundness": null,
      "seed": 1907383705,
      "version": 864,
      "versionNonce": 1500639423,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1751920298362,
      "link": null,
      "locked": false,
      "text": "'use step' client transformation\n* in default/no layer\n  * becomes newtork fetch Promise\n* in 'workflow' layer\n  * becomes a promise that throws/resolves\n* in 'step' layer\n  * becomes a network fetc promise\n  * 'warning' to user that nested step calls should\n    probably be hoisted to the workflow",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "'use step' client transformation\n* in default/no layer\n  * becomes newtork fetch Promise\n* in 'workflow' layer\n  * becomes a promise that throws/resolves\n* in 'step' layer\n  * becomes a network fetc promise\n  * 'warning' to user that nested step calls should\n    probably be hoisted to the workflow",
      "autoResize": true,
      "lineHeight": 1.25
    },
