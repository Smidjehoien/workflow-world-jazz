      "boundElements": [],
      "updated": 1751920295950,
      "link": null,
      "locked": false,
      "text": "Easy to accidentally make a step/workflow have\nunserializable args/return. Need compiler and runtime\nvalidation.\nIf a class implements .toJSON and .fromJSON, we could\ntheoretically support passing instances of that class. Just\nneed a handle to the class in the context.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Easy to accidentally make a step/workflow have unserializable args/return. Need compiler and runtime validation.\nIf a class implements .toJSON and .fromJSON, we could theoretically support passing instances of that class. Just\nneed a handle to the class in the context.",
      "autoResize": false,
      "lineHeight": 1.25
    },
