      "type": "text",
      "x": 1890.222886654065,
      "y": 281.73457972077944,
      "width": 358.6624548835121,
      "height": 108,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
