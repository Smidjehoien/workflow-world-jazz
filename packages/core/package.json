      "node": "./dist/observability.js"
    },
    "./parse-name": {
      "types": "./dist/parse-name.d.ts",
      "default": "./dist/parse-name.js"
    },
    "./_workflow": "./dist/workflow/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "tsc --build --clean && rm -r dist ||:",
