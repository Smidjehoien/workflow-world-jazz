{
  "name": "@vercel/workflow-errors",
  "description": "A package for standardizing errors in Workflow SDK.",
  "version": "0.0.1-alpha.5",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "tsc --build --clean && rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "catalog:",
    "@vercel/workflow-tsconfig": "workspace:*"
  },
  "dependencies": {
    "ms": "2.1.3"
  }
}
