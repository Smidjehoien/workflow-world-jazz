{
  "name": "@vercel/workflow",
  "version": "0.0.1-alpha.15",
  "main": "dist/index.cjs",
  "type": "module",
  "bin": {
    "workflow": "./bin/run.js",
    "wf": "./bin/run.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workflow": "./dist/workflow.js",
      "default": "./dist/index.js"
    },
    "./ai": "./dist/ai.js",
    "./api": "./dist/api.js",
    "./internal/errors": "./dist/internal/errors.js",
    "./internal/serialization": "./dist/internal/serialization.js",
    "./internal/builtins": "./dist/internal/builtins.js",
    "./internal/private": "./dist/internal/private.js",
    "./next": "./dist/next.js",
    "./runtime": "./dist/runtime.js"
  },
  "scripts": {
    "build": "tsc && chmod +x bin/run.js",
    "clean": "tsc --build --clean && rm -r dist ||:",
    "dev": "tsc --watch",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/workflow-cli": "workspace:*",
    "@vercel/workflow-core": "workspace:*",
    "@vercel/workflow-errors": "workspace:*",
    "@vercel/workflow-typescript-plugin": "workspace:*",
    "ms": "2.1.3",
    "@vercel/workflow-ai": "workspace:*",
    "@vercel/workflow-next": "workspace:*"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "catalog:",
    "@vercel/workflow-tsconfig": "workspace:*"
  },
  "peerDependencies": {
    "@opentelemetry/api": "1"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
